# ==============================================================================
# SwasthyaNetram Environment Configuration Template (.env.example)
# Rename this file to '.env' inside the 'backend' folder and update values.
# ==============================================================================

# --- Django Settings ---
SECRET_KEY=django-insecure-development-secret-key-replace-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- AI Chat Integration ---
# Retrieve a free key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database Selection (Choose ONE of the Options below) ---

# Option A: Local PostgreSQL via Docker Compose (Recommended)
# Run `docker compose up -d` in the project root, then use this:
DATABASE_URL=postgres://postgres:postgres@localhost:5433/swasthya_db

# Option B: Local PostgreSQL (Native/Local installation on host OS)
# Replace 'username', 'password', and 'db_name' with your local PostgreSQL credentials:
# DATABASE_URL=postgres://username:password@localhost:5432/db_name

# Option C: Supabase (PostgreSQL with SSL mode)
# Copy the connection URI from your Supabase Project Settings -> Database settings.
# For Django, the connection URI usually uses port 5432 (or 6543 for pooling) and require SSL.
# DATABASE_URL=postgres://postgres.xxxxxx:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# Option D: SQLite Fallback (Default when no DATABASE_URL is set)
# Leave DATABASE_URL blank or comment it out to fall back to the local sqlite database.

# --- LangSmith AI Monitoring ---
# To monitor and trace your LangChain LLM execution, set LANGCHAIN_TRACING_V2 to true
# and obtain an API Key from https://smith.langchain.com/
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT="swasthya-netram"
